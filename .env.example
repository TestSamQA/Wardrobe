# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://wardrobe:CHANGEME@localhost:5432/wardrobe"
POSTGRES_USER=wardrobe
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=wardrobe

# ── Auth.js ───────────────────────────────────────────────────────────────────
NEXTAUTH_URL="https://your.domain.com"
# Generate with: openssl rand -base64 32
AUTH_SECRET="CHANGEME"

# ── Email (magic link) ────────────────────────────────────────────────────────
EMAIL_SERVER="smtp://user:pass@smtp.example.com:587"
EMAIL_FROM="Wardrobe <noreply@your.domain.com>"

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── Replicate (outfit flatlay image generation) ────────────────────────────────
# Get your token at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN="r8_..."

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGEME_MINIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGEME_MINIO
MINIO_BUCKET_IMAGES=wardrobe-images
MINIO_BUCKET_THUMBNAILS=wardrobe-thumbnails

MINIO_PUBLIC_BASE_URL=/api/images

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your.domain.com"
